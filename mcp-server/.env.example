# URL du projet Supabase myFridge
SUPABASE_URL=https://acrozolmszroqegeluch.supabase.co

# Clé publishable / anon (Project Settings > API). Pas un secret côté serveur.
SUPABASE_ANON_KEY=sb_publishable_xxx

# Identifiants de connexion de ton compte myFridge.
# Le serveur se connecte avec ces identifiants : les RLS s'appliquent et il ne
# voit que TES données. Le compte doit avoir une connexion email/mot de passe
# (pas seulement Google/Apple).
MYFRIDGE_EMAIL=
MYFRIDGE_PASSWORD=
