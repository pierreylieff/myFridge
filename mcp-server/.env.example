# URL du projet Supabase myFridge
SUPABASE_URL=https://acrozolmszroqegeluch.supabase.co

# Clé "service_role" (Project Settings > API > service_role secret).
# Elle contourne les RLS : le serveur peut donc lire toutes les données.
# NE JAMAIS committer ce fichier ni exposer cette clé côté client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optionnel : restreindre l'accès à un seul utilisateur.
# Renseigner SOIT l'email (résolu via la table profiles), SOIT l'id (uuid auth.users).
# Si aucun n'est fourni, le serveur agrège les données de tous les utilisateurs.
MYFRIDGE_USER_EMAIL=
MYFRIDGE_USER_ID=
